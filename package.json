{
  "name": "zeroquarry-docs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "sync:openapi": "node scripts/sync-openapi.js",
    "gen:api": "npm run sync:openapi && docusaurus gen-api-docs all && node scripts/prepare-api-sidebar.js",
    "start": "npm run gen:api && docusaurus start --host 0.0.0.0",
    "build": "npm run gen:api && docusaurus build",
    "serve": "docusaurus serve --host 0.0.0.0",
    "clear": "docusaurus clear && docusaurus clean-api-docs all"
  },
  "dependencies": {
    "@docusaurus/core": "^3.10.0",
    "@docusaurus/preset-classic": "^3.10.0",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.1.1",
    "docusaurus-plugin-openapi-docs": "^5.0.0",
    "docusaurus-theme-openapi-docs": "^5.0.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "overrides": {
    "webpackbar": "^7.0.0"
  },
  "devDependencies": {}
}
